# =============================================================================
# Multi-Agent Business Research Assistant — Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in your API keys.
#
#   cp .env.example .env
#
# Required API Keys:
#   - XAI_API_KEY:    Obtain from https://console.x.ai/
#   - TAVILY_API_KEY: Obtain from https://tavily.com/
# =============================================================================

# ── xAI / Grok API ──────────────────────────────────────────────────────────
XAI_API_KEY=your_xai_api_key_here

# ── Tavily Search API ────────────────────────────────────────────────────────
TAVILY_API_KEY=your_tavily_api_key_here

# ── Optional: LangSmith Tracing (for debugging & observability) ──────────────
# LANGSMITH_API_KEY=your_langsmith_api_key_here
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=multi-agent-research
